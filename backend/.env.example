# ========================================
# FiveMinds Backend — Railway + Supabase
# ========================================

# Supabase PostgreSQL connection string
# Get from: Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Security — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# Environment
ENVIRONMENT=production

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# Also set allowed origins (comma-separated, include localhost for dev)
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# Optional: LLM keys for real AI insights
GROQ_API_KEY=
OPENAI_API_KEY=
